# SimpleCrawler 专用 PostgreSQL 数据库。数据库需要在运行脚本前创建。
SIMPLE_CRAWLER_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/football_simple

# 允许进入详情、赔率和完成核验脚本的 match_ids.crawl_status，英文逗号分隔。
# 默认只处理未完成；已完成、暂停爬取和异常不会再次进入抓取流程。
SIMPLE_CRAWLER_ACTIVE_CRAWL_STATUSES=未完成

# 比赛列表页地址。
SIMPLE_CRAWLER_LIST_URL=https://live.titan007.com/oldIndexall.aspx

# 列表页导航、等待比赛行时，每一步最多等待的秒数，必须大于 0。
SIMPLE_CRAWLER_LIST_TIMEOUT_SECONDS=15

# 第一条比赛行出现后额外等待的秒数，用于等待列表渲染完整，可以为 0。
SIMPLE_CRAWLER_LIST_SETTLE_SECONDS=1

# 详情页地址模板；{match_id} 会替换成实际比赛 ID。
SIMPLE_CRAWLER_DETAIL_URL_TEMPLATE=https://live.titan007.com/detail/{match_id}sb.htm

# 每个详情页导航、等待详情头部时，每一步最多等待的秒数，必须大于 0。
SIMPLE_CRAWLER_DETAIL_TIMEOUT_SECONDS=15

# 同时抓取的详情页数量，必须大于 0。
SIMPLE_CRAWLER_DETAIL_CONCURRENCY=2

# 每次最多抓取的详情数量。留空表示处理全部待抓取比赛。
SIMPLE_CRAWLER_DETAIL_LIMIT=

# 是否显示 Chromium 窗口。支持 true/false、1/0、yes/no、on/off。
SIMPLE_CRAWLER_HEADED=false

# 必填代理供应商配置。所有页面请求都必须先从调度器领取代理 IP。
# API 应返回纯文本 host:port，每次请求配置为返回 10 个地址。
PROXY_API_URL=https://proxy-supplier.example/getip?qty=10
PROXY_USERNAME=replace-me
PROXY_PASSWORD=replace-me

# 调度器每 2 秒提取一批；每个 IP 从提取请求开始 30 秒后过期。
PROXY_REFRESH_SECONDS=2
PROXY_TTL_SECONDS=30

# 代理 API 请求超时，以及页面等待调度器分配可用 IP 的超时。
PROXY_API_TIMEOUT_SECONDS=5
PROXY_ACQUIRE_TIMEOUT_SECONDS=15

# 多个脚本同时运行时，共享此最小供应商请求间隔，避免跨进程触发限流。
PROXY_API_MIN_INTERVAL_SECONDS=2

# 唯一代理调度服务监听地址。爬取脚本只连接此 URL，不直接调用供应商。
PROXY_SCHEDULER_HOST=127.0.0.1
PROXY_SCHEDULER_PORT=8765
PROXY_SCHEDULER_URL=http://127.0.0.1:8765
PROXY_CLIENT_TIMEOUT_SECONDS=20

# 新 IP 入池前必须通过此页面验证；10 个 IP 默认并发验证，单个最多 5 秒。
PROXY_TEST_URL=https://live.titan007.com/oldIndexall.aspx
PROXY_TEST_TIMEOUT_SECONDS=5
PROXY_VALIDATION_WORKERS=10

# 赔率变化页基础地址模板；{endpoint} 会替换为三个市场各自的页面文件名。
SIMPLE_CRAWLER_ODDS_BASE_URL=https://vip.titan007.com/changeDetail/{endpoint}

# 要抓取的公司 ID，使用英文逗号分隔；每家公司固定抓取三个市场页面。
SIMPLE_CRAWLER_ODDS_COMPANY_IDS=3,4,8,24,31,47

# 每个赔率页面导航、等待表格时，每一步最多等待的秒数，必须大于 0。
SIMPLE_CRAWLER_ODDS_TIMEOUT_SECONDS=15

# 同时抓取的“比赛 × 公司 × 市场”赔率页面数量，必须大于 0。
SIMPLE_CRAWLER_ODDS_PAGE_CONCURRENCY=4

# 每次最多处理的比赛数量。留空表示处理 match_ids 中的全部比赛。
SIMPLE_CRAWLER_ODDS_MATCH_LIMIT=

# 完场核验脚本每次最多检查的比赛数量。留空表示检查全部待核验完场比赛。
SIMPLE_CRAWLER_COMPLETION_MATCH_LIMIT=

# 总调度器监控页面，默认访问 http://127.0.0.1:8081/。
# 设为 0 可关闭监控 HTTP 服务；修改 HOST 为 0.0.0.0 前请配置网络访问控制。
SIMPLE_CRAWLER_MONITOR_HOST=127.0.0.1
SIMPLE_CRAWLER_MONITOR_PORT=8081
